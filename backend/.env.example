# Copy this file to .env and fill in your real values

# Get a free key at https://www.electricitymaps.com/free-tier-api
CARBON_API_KEY=your_electricitymaps_key_here
CARBON_API_ZONE=IN

# Where your monitored application exposes its /metrics endpoint
# (see docs/monitored-app.md — leave as-is to use the built-in local simulator)
MONITORED_APP_URL=http://127.0.0.1:9000/metrics

# Database
DATABASE_PATH=database/orchestrator.db
